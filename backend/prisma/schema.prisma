generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  E_WALLET
}

enum QueueJobStatus {
  WAITING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Users ───────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  role         UserRole  @default(USER)
  refreshToken String?
  avatarUrl    String?
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings  Booking[]
  queueJobs QueueJob[]

  @@index([email])
  @@map("users")
}

// ─── Concerts ────────────────────────────────────────

model Concert {
  id          String        @id @default(uuid())
  title       String
  description String
  artist      String
  venue       String
  address     String
  city        String
  date        DateTime
  imageUrl    String?
  status      ConcertStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ticketTypes TicketType[]
  bookings    Booking[]
  queueJobs   QueueJob[]

  @@index([date])
  @@index([status])
  @@index([city])
  @@map("concerts")
}

// ─── Ticket Types ────────────────────────────────────

model TicketType {
  id             String   @id @default(uuid())
  concertId      String
  name           String
  description    String?
  price          Decimal  @db.Decimal(12, 2)
  totalSeats     Int
  availableSeats Int
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  concert      Concert       @relation(fields: [concertId], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]

  @@index([concertId])
  @@map("ticket_types")
}

// ─── Bookings ────────────────────────────────────────

model Booking {
  id          String        @id @default(uuid())
  userId      String
  concertId   String
  status      BookingStatus @default(PENDING)
  totalAmount Decimal       @db.Decimal(12, 2)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  concert      Concert       @relation(fields: [concertId], references: [id])
  bookingItems BookingItem[]
  payment      Payment?
  queueJob     QueueJob?

  @@index([userId])
  @@index([concertId])
  @@index([status])
  @@index([expiresAt])
  @@map("bookings")
}

// ─── Booking Items ───────────────────────────────────

model BookingItem {
  id           String  @id @default(uuid())
  bookingId    String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  subtotal     Decimal @db.Decimal(12, 2)

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([bookingId])
  @@map("booking_items")
}

// ─── Payments ────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  failureReason String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status])
  @@map("payments")
}

// ─── Queue Jobs ──────────────────────────────────────

model QueueJob {
  id          String         @id @default(uuid())
  bookingId   String?        @unique
  userId      String
  concertId   String
  status      QueueJobStatus @default(WAITING)
  position    Int?
  jobData     Json?
  result      Json?
  errorMsg    String?
  processedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  concert Concert  @relation(fields: [concertId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([status])
  @@index([userId])
  @@index([concertId])
  @@map("queue_jobs")
}
